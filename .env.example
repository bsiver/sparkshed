# Sparkshed Environment Variables

# Django secret key for production. Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Database URL (optional). If not set, uses SQLite.
# For PostgreSQL on Render: postgresql://user:password@host:port/dbname
# For local PostgreSQL: postgresql://postgres:postgres@localhost:5432/sparkshed
# DATABASE_URL=

# Render deployment hostname (set automatically by Render)
# RENDER_EXTERNAL_HOSTNAME=sparkshed.onrender.com

# Superuser credentials (used by build.sh / createsu command)
SU_USERNAME=admin
SU_PASSWORD=admin
